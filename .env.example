# ============================================================
# HolidaySaver — Environment Variables
# Copy this file to .env.local and fill in each value.
# ============================================================

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- Database -----------------------------------------------------------
# SQLite (default for local dev — just a file, no setup needed)
DATABASE_URL="file:./dev.db"

# Postgres (uncomment for production on Vercel / Railway / Supabase)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/holidaysaver?sslmode=require"

# --- Google OAuth (optional — magic-link email works without this) -----
# Create credentials at https://console.cloud.google.com/
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Email (for magic link sign-in) ------------------------------------
# Nodemailer SMTP — use any SMTP provider (Gmail, Resend, Mailgun, etc.)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=HolidaySaver <noreply@yourdomain.com>

# For Resend (simpler alternative): set host=smtp.resend.com, port=465,
# user=resend, password=<resend api key>
