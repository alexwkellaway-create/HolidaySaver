# ============================================================
# HolidaySaver — Environment Variables
# ============================================================

# 1. Generate a secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secret-here

# 2. Your app URL
#    Local dev:  http://localhost:3000
#    Netlify:    https://your-site-name.netlify.app
NEXTAUTH_URL=http://localhost:3000

# 3. Postgres database — get a free one at neon.tech
#    After creating a project, copy the connection string (the pooled one)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/holidaysaver?sslmode=require
