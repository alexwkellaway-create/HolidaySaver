# ============================================================
# HolidaySaver — Environment Variables
# ============================================================

# 1. Generate a secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secret-here

# 2. Your app URL
#    Local dev:  http://localhost:3000
#    Netlify:    https://your-site-name.netlify.app
NEXTAUTH_URL=http://localhost:3000

# 3. Supabase session pooler URL (works on IPv4, no extra config needed)
#    Supabase → Settings → Database → Connection pooling → Session mode → copy URI
#    Username format: postgres.YOURPROJECTREF
#    Host format:     aws-0-YOURREGION.pooler.supabase.com  port: 5432
DATABASE_URL=postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-YOURREGION.pooler.supabase.com:5432/postgres
