# ============================================================
# HolidaySaver — Environment Variables
# Copy this file to .env.local and fill in the three values.
# ============================================================

# Generate with: openssl rand -base64 32
# Or get one from: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secret-here

# Your app's URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# SQLite for local dev (just a file — no setup needed)
DATABASE_URL="file:./dev.db"

# --- Production (Vercel) only -----------------------------------
# Swap DATABASE_URL to Postgres, e.g. from neon.tech (free tier):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/holidaysaver?sslmode=require"
# NEXTAUTH_URL=https://your-app.vercel.app
