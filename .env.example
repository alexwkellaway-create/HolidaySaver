# ============================================================
# HolidaySaver — Environment Variables
# ============================================================

# 1. Generate a secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secret-here

# 2. Your app URL
#    Local dev:  http://localhost:3000
#    Netlify:    https://your-site-name.netlify.app
NEXTAUTH_URL=http://localhost:3000

# 3. Supabase Postgres — get both strings from:
#    Supabase dashboard → Settings → Database → Connection string
#
#    DATABASE_URL  = "Transaction" pooler URL (port 6543)
#    Add ?pgbouncer=true to the end of DATABASE_URL
DATABASE_URL=postgresql://postgres.XXXX:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
#
#    DIRECT_URL = the plain URI (port 5432) — used for db push / migrations
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.XXXX.supabase.co:5432/postgres
