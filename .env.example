# ============================================================
# HolidaySaver — Environment Variables
# ============================================================

# 1. Generate a secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secret-here

# 2. Your app URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# 3. Neon Postgres — get a free DB at neon.tech
#    After creating a project, copy the two connection strings:
DATABASE_URL=postgresql://USER:PASSWORD@HOST/holidaysaver?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/holidaysaver?sslmode=require
#    (On Neon, DATABASE_URL uses the pooled connection, DIRECT_URL is the direct one)
